# ==============================================================================
# 1. Google OAuth & Calendar Credentials
# ==============================================================================
# You need a Google Cloud Project with the Calendar API enabled.
# Generate OAuth 2.0 Client ID credentials (type: Web application or Desktop app).
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Run the local script `node scripts/generate-token.js` to get this refresh token:
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# The calendar where events will be created (usually your primary email address)
HOST_CALENDAR_ID=your.email@gmail.com

# ==============================================================================
# 2. Host Profile Information
# ==============================================================================
HOST_NAME="Your Name"
HOST_EMAIL="your.email@gmail.com"
HOST_TIMEZONE="Africa/Lagos"

# ==============================================================================
# 3. Email Settings (Nodemailer + Gmail SMTP)
# ==============================================================================
# To get an App Password:
# 1. Go to Google Account Security settings
# 2. Enable 2-Step Verification if not already on
# 3. Search "App passwords" in the top search bar
# 4. Generate a new password (select "Other", name it "Personal Scheduler")
# 5. Paste the 16-character code below without spaces

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_character_app_password

# ==============================================================================
# 4. Application Settings
# ==============================================================================
# URL for the app (e.g., http://localhost:3000 in dev, or your Vercel domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
